# Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
STORAGE_ROOT=.
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Virtual Try-On
# Set to "mock" for development without GPU / model download
CATVTON_MODEL_ID=hf_spaces
CATVTON_DEVICE=cpu
HF_TOKEN=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

# Scene Generation
# Options: mock | flux | gpt_image | sdxl | hf_inference
# hf_inference = free, uses HF_TOKEN above, generates real AI scene from prompt
SCENE_PROVIDER=hf_inference
FLUX_API_KEY=
FLUX_MODEL_ID=black-forest-labs/FLUX.1-schnell
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
SDXL_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
SDXL_DEVICE=cpu

# Job Store
# Options: memory | redis
JOB_STORE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Prompt (must be a single line — use \n for line breaks if needed)
SCENE_PROMPT_TEMPLATE=Use the uploaded virtual try-on image as the primary subject and preserve the person's identity, facial features, body proportions, skin tone, hairstyle, pose, and the exact outfit details. Place the person on a luxurious Indian wedding stage with elegant royal wedding decoration featuring rich floral arrangements with fresh roses, marigolds, orchids, and jasmine flowers, premium golden pillars, crystal chandeliers, decorative hanging lights, traditional wedding elements, and a grand wedding backdrop. Create a bright, vibrant, and highly realistic wedding atmosphere with cinematic lighting, warm golden tones, professional event lighting, soft facial illumination, realistic shadows, depth of field, and premium wedding photography aesthetics. Enhance the overall appearance with natural professional bridal makeup appropriate to the outfit, flawless skin, bright and healthy facial glow, subtle beauty enhancement, realistic facial detailing, and elegant jewelry that perfectly matches the outfit style, color, and wedding theme. The final image should look like a real wedding photoshoot captured by a professional photographer. Ultra realistic, photorealistic, 8K quality, highly detailed, sharp focus, natural skin texture, realistic fabric details, luxury wedding ambiance, premium wedding stage, studio-quality lighting, masterpiece quality.
